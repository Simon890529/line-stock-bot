# ─────────────────────────────────────────────
# LINE Bot 設定（必填）
# ─────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# 您個人的 LINE User ID（啟動後傳「我的ID」取得）
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# 追蹤持股（逗號分隔，可透過 Line 指令隨時調整）
# ─────────────────────────────────────────────
DEFAULT_WATCHLIST=2454,2327,2330

# ─────────────────────────────────────────────
# 5 檔主動型 ETF
# ─────────────────────────────────────────────
ETF1_CODE=00981A
ETF1_NAME=主動統一台股增長
ETF1_COMPANY=president

ETF2_CODE=00982A
ETF2_NAME=主動群益台灣強棒
ETF2_COMPANY=capital

ETF3_CODE=00991A
ETF3_NAME=主動復華未來50
ETF3_COMPANY=fuh-hwa

ETF4_CODE=00992A
ETF4_NAME=主動群益科技創新
ETF4_COMPANY=capital

ETF5_CODE=00993A
ETF5_NAME=主動安聯台灣
ETF5_COMPANY=allianz

# ─────────────────────────────────────────────
# （選填）Google Sheets CSV 備援（ETF爬蟲失效時使用）
# 格式：代碼=CSV_URL，多筆以分號分隔
# ─────────────────────────────────────────────
# ETF_GSHEET_URLS=00981A=https://docs.google.com/...csv;00982A=https://...

# ─────────────────────────────────────────────
# Cron Job 安全密碼
# ─────────────────────────────────────────────
CRON_SECRET=change_me_to_random_string

# 本機測試用（雲端請用 Render Cron Job）
USE_APSCHEDULER=false

DATA_DIR=./data
